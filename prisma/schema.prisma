generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  initializing
  active
  paused
  completed
  closed
}

enum EnvironmentType {
  default
  temporary
  module
}

enum EnvironmentStatus {
  creating
  active
  disabled
  error
}

enum RepoSyncStatus {
  uninitialized
  syncing
  ready
  error
}

enum RepoAccessMode {
  readonly
  write_protected
}

enum SourceType {
  group
  private
}

enum AgentRunStatus {
  queued
  running
  syncing
  succeeded
  failed
  canceled
  timeout
}

enum AgentRunType {
  formal_execution
  runtime_audit
  bootstrap
  digest
}

enum ArtifactType {
  document
  task
  file
  execution_log
  summary
}

enum ArtifactStatus {
  pending
  synced
  failed
  skipped
}

enum ConfirmationStatus {
  pending
  confirmed
  rejected
  expired
}

enum AgentRole {
  manager
}

enum GroupSessionMode {
  bootstrap
  active
  disabled
}

enum GroupSessionStatus {
  idle
  busy
  error
  disabled
}

enum GroupRuntimeTaskStatus {
  queued
  running
  blocked
  waiting_confirmation
  completed
  failed
  canceled
}

enum RuntimeQueueMode {
  steer
  followup
  collect
  interrupt
  steer_backlog
}

model Project {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String
  description          String?
  ownerOpenId          String               @map("owner_open_id")
  feishuChatId         String               @unique @map("feishu_chat_id")
  status               ProjectStatus        @default(initializing)
  docFolderToken       String?              @map("doc_folder_token")
  bitableAppToken      String?              @map("bitable_app_token")
  bitableTableId       String?              @map("bitable_table_id")
  docChatTabId         String?              @map("doc_chat_tab_id")
  bitableChatTabId     String?              @map("bitable_chat_tab_id")
  defaultEnvironmentId String?              @map("default_environment_id") @db.Uuid
  defaultSkillSet      Json                 @default("{}") @map("default_skill_set")
  createdBy            String               @map("created_by")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  environments         ProjectEnvironment[]
  messageSources       MessageSource[]
  agentRuns            AgentRun[]
  artifacts            Artifact[]
  confirmations        ConfirmationRequest[]
  groupAgentSessions   GroupAgentSession[]
  runtimeTasks         GroupRuntimeTask[]
  agentProfileOverrides ProjectAgentProfileOverride[]
  groupPolicies        GroupPolicy[]
  memberProfiles       ProjectMemberProfile[]
  runtimeEvents        RuntimeEvent[]

  @@map("projects")
}

model ProjectEnvironment {
  id             String            @id @default(uuid()) @db.Uuid
  projectId      String            @map("project_id") @db.Uuid
  name           String
  type           EnvironmentType   @default(default)
  piMonoEnvId    String?           @map("pi_mono_env_id")
  repoUrl        String?           @map("repo_url")
  repoBranch     String?           @map("repo_branch")
  repoCredentialRef String?        @map("repo_credential_ref")
  repoAccessMode RepoAccessMode    @default(readonly) @map("repo_access_mode")
  repoMirrorPath String?           @map("repo_mirror_path")
  repoSyncStatus RepoSyncStatus    @default(uninitialized) @map("repo_sync_status")
  repoSyncError  String?           @map("repo_sync_error")
  lastRepoSyncAt DateTime?         @map("last_repo_sync_at")
  repoHeadRef    String?           @map("repo_head_ref")
  projectPath    String?           @map("project_path")
  modelEndpoint  String?           @map("model_endpoint")
  modelName      String?           @map("model_name")
  skillSet       Json              @default("{}") @map("skill_set")
  outputDir      String?           @map("output_dir")
  logUri         String?           @map("log_uri")
  status         EnvironmentStatus @default(creating)
  createdBy      String            @map("created_by")
  createdAt      DateTime          @default(now()) @map("created_at")
  lastActiveAt   DateTime?         @map("last_active_at")
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messageSources MessageSource[]
  agentRuns      AgentRun[]
  artifacts      Artifact[]
  confirmations  ConfirmationRequest[]
  groupAgentSessions GroupAgentSession[] @relation("GroupSessionEnvironment")
  runtimeTasks   GroupRuntimeTask[]
  groupPolicies  GroupPolicy[]
  runtimeEvents  RuntimeEvent[]

  @@index([projectId])
  @@map("project_environments")
}

model MessageSource {
  id              String              @id @default(uuid()) @db.Uuid
  projectId       String?             @map("project_id") @db.Uuid
  environmentId   String?             @map("environment_id") @db.Uuid
  sourceType      SourceType          @map("source_type")
  feishuEventId   String              @map("feishu_event_id")
  feishuChatId    String              @map("feishu_chat_id")
  feishuMessageId String              @map("feishu_message_id")
  senderOpenId    String              @map("sender_open_id")
  rawText         String              @map("raw_text")
  rawContentJson  Json?               @map("raw_content_json")
  mentionsJson    Json?               @map("mentions_json")
  isBotMentioned  Boolean             @default(false) @map("is_bot_mentioned")
  receivedAt      DateTime            @default(now()) @map("received_at")
  traceId         String              @map("trace_id")
  project         Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment     ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  agentRuns       AgentRun[]
  artifacts       Artifact[]
  confirmations   ConfirmationRequest[]
  groupRuntimeTasks GroupRuntimeTask[]

  @@unique([feishuMessageId, senderOpenId])
  @@index([feishuEventId])
  @@map("message_sources")
}

model AgentRun {
  id              String              @id @default(uuid()) @db.Uuid
  projectId       String              @map("project_id") @db.Uuid
  environmentId   String              @map("environment_id") @db.Uuid
  messageSourceId String?             @map("message_source_id") @db.Uuid
  groupRuntimeTaskId String?          @map("group_runtime_task_id") @db.Uuid
  piMonoRunId     String?             @map("pi_mono_run_id")
  runType         AgentRunType        @default(formal_execution) @map("run_type")
  intent          String
  skillName       String?             @map("skill_name")
  prompt          String
  status          AgentRunStatus      @default(queued)
  progress        Int                 @default(0)
  outputSummary   String?             @map("output_summary")
  errorCode       String?             @map("error_code")
  errorMessage    String?             @map("error_message")
  rawOutputs      Json?               @map("raw_outputs")
  startedAt       DateTime?           @map("started_at")
  finishedAt      DateTime?           @map("finished_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     ProjectEnvironment  @relation(fields: [environmentId], references: [id])
  messageSource   MessageSource?      @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)
  groupRuntimeTask GroupRuntimeTask?  @relation(fields: [groupRuntimeTaskId], references: [id], onDelete: SetNull)
  artifacts       Artifact[]
  currentInGroupSessions GroupAgentSession[] @relation("CurrentGroupRun")

  @@index([status])
  @@index([piMonoRunId])
  @@map("agent_runs")
}

model Artifact {
  id              String              @id @default(uuid()) @db.Uuid
  projectId       String              @map("project_id") @db.Uuid
  environmentId   String?             @map("environment_id") @db.Uuid
  agentRunId      String?             @map("agent_run_id") @db.Uuid
  groupRuntimeTaskId String?          @map("group_runtime_task_id") @db.Uuid
  messageSourceId String?             @map("message_source_id") @db.Uuid
  type            ArtifactType
  title           String
  status          ArtifactStatus      @default(pending)
  feishuUrl       String?             @map("feishu_url")
  feishuToken     String?             @map("feishu_token")
  bitableRecordId String?             @map("bitable_record_id")
  fileKey         String?             @map("file_key")
  contentHash     String?             @map("content_hash")
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now()) @map("created_at")
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  agentRun        AgentRun?           @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  groupRuntimeTask GroupRuntimeTask?  @relation(fields: [groupRuntimeTaskId], references: [id], onDelete: SetNull)
  messageSource   MessageSource?      @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)

  @@unique([projectId, type, contentHash])
  @@index([status])
  @@map("artifacts")
}

model ConfirmationRequest {
  id              String              @id @default(uuid()) @db.Uuid
  projectId       String?             @map("project_id") @db.Uuid
  environmentId   String?             @map("environment_id") @db.Uuid
  messageSourceId String              @map("message_source_id") @db.Uuid
  groupRuntimeTaskId String?          @map("group_runtime_task_id") @db.Uuid
  actionType      String              @map("action_type")
  payload         Json
  status          ConfirmationStatus  @default(pending)
  cardMessageId   String?             @map("card_message_id")
  confirmedBy     String?             @map("confirmed_by")
  expiresAt       DateTime            @map("expires_at")
  decidedAt       DateTime?           @map("decided_at")
  project         Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  groupRuntimeTask GroupRuntimeTask?  @relation(fields: [groupRuntimeTaskId], references: [id], onDelete: SetNull)
  messageSource   MessageSource       @relation(fields: [messageSourceId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@map("confirmation_requests")
}

model ConversationContext {
  id            String     @id @default(uuid()) @db.Uuid
  sourceType    SourceType @map("source_type")
  feishuChatId  String     @map("feishu_chat_id")
  userOpenId    String?    @map("user_open_id")
  projectId     String?    @map("project_id") @db.Uuid
  environmentId String?    @map("environment_id") @db.Uuid
  expiresAt     DateTime   @map("expires_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@unique([sourceType, feishuChatId, userOpenId])
  @@index([expiresAt])
  @@map("conversation_contexts")
}

model GroupAgentSession {
  id                  String             @id @default(uuid()) @db.Uuid
  projectId           String?            @map("project_id") @db.Uuid
  feishuChatId        String             @map("feishu_chat_id")
  agentRole           AgentRole          @default(manager) @map("agent_role")
  agentScopeKey       String             @map("agent_scope_key")
  runtimeSessionKey   String             @map("runtime_session_key")
  sessionMode         GroupSessionMode   @default(bootstrap) @map("session_mode")
  status              GroupSessionStatus @default(idle)
  activeEnvironmentId String?            @map("active_environment_id") @db.Uuid
  piSessionId         String?            @map("pi_session_id")
  sessionStoreDriver  String?            @map("session_store_driver")
  sessionStoreRef     String?            @map("session_store_ref")
  currentAgentRunId   String?            @unique @map("current_agent_run_id") @db.Uuid
  currentRuntimeTaskId String?           @unique @map("current_runtime_task_id") @db.Uuid
  activeLockToken     String?            @map("active_lock_token")
  memorySummary       String?            @map("memory_summary")
  sessionState        Json               @default("{}") @map("session_state")
  summaryPolicyJson   Json               @default("{}") @map("summary_policy_json")
  runtimeStateJson    Json               @default("{}") @map("runtime_state_json")
  lastMessageAt       DateTime?          @map("last_message_at")
  lastRunAt           DateTime?          @map("last_run_at")
  lastRuntimeTurnAt   DateTime?          @map("last_runtime_turn_at")
  lastDigestAt        DateTime?          @map("last_digest_at")
  lastDigestType      String?            @map("last_digest_type")
  lastDigestHash      String?            @map("last_digest_hash")
  lastDigestRunId     String?            @map("last_digest_run_id") @db.Uuid
  lastError           String?            @map("last_error")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  activeEnvironment   ProjectEnvironment? @relation("GroupSessionEnvironment", fields: [activeEnvironmentId], references: [id], onDelete: SetNull)
  currentAgentRun     AgentRun?          @relation("CurrentGroupRun", fields: [currentAgentRunId], references: [id], onDelete: SetNull)
  currentRuntimeTask  GroupRuntimeTask?  @relation("CurrentRuntimeTask", fields: [currentRuntimeTaskId], references: [id], onDelete: SetNull)
  runtimeTasks        GroupRuntimeTask[]
  runtimeEvents       RuntimeEvent[]

  @@unique([projectId, agentRole])
  @@unique([feishuChatId, agentRole])
  @@index([status, feishuChatId])
  @@map("group_agent_sessions")
}

model FeishuEventDedup {
  eventId   String   @id @map("event_id")
  messageId String?  @map("message_id")
  handledAt DateTime @default(now()) @map("handled_at")
  traceId   String   @map("trace_id")

  @@map("feishu_event_dedup")
}

model GroupRuntimeTask {
  id                    String                 @id @default(uuid()) @db.Uuid
  groupSessionId        String                 @map("group_session_id") @db.Uuid
  projectId             String                 @map("project_id") @db.Uuid
  environmentId         String                 @map("environment_id") @db.Uuid
  messageSourceId       String?                @map("message_source_id") @db.Uuid
  title                 String
  description           String?
  intent                String
  skillHint             String?                @map("skill_hint")
  outputMode            String?                @map("output_mode")
  orderIndex            Int                    @default(0) @map("order_index")
  status                GroupRuntimeTaskStatus @default(queued)
  blockedReason         String?                @map("blocked_reason")
  nextActionHint        String?                @map("next_action_hint")
  priority              Int                    @default(0)
  triggerType           String?                @map("trigger_type")
  taskPayloadJson       Json                   @default("{}") @map("task_payload_json")
  resultSummary         String?                @map("result_summary")
  lastError             String?                @map("last_error")
  startedAt             DateTime?              @map("started_at")
  finishedAt            DateTime?              @map("finished_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  groupSession          GroupAgentSession      @relation(fields: [groupSessionId], references: [id], onDelete: Cascade)
  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment           ProjectEnvironment     @relation(fields: [environmentId], references: [id])
  messageSource         MessageSource?         @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)
  confirmationRequests  ConfirmationRequest[]
  agentRuns             AgentRun[]
  artifacts             Artifact[]
  currentInGroupSessions GroupAgentSession[]   @relation("CurrentRuntimeTask")

  @@index([groupSessionId, orderIndex, createdAt])
  @@index([projectId, status])
  @@map("group_runtime_tasks")
}

model GroupPolicy {
  id                                String              @id @default(uuid()) @db.Uuid
  projectId                         String              @map("project_id") @db.Uuid
  feishuChatId                      String              @map("feishu_chat_id")
  enabled                           Boolean             @default(true)
  mentionOnly                       Boolean             @default(true) @map("mention_only")
  defaultQueueMode                  RuntimeQueueMode    @default(collect) @map("default_queue_mode")
  allowedSkillsJson                 Json                @default("[]") @map("allowed_skills_json")
  defaultEnvironmentId              String?             @map("default_environment_id") @db.Uuid
  allowAutoTaskCreation             Boolean             @default(true) @map("allow_auto_task_creation")
  allowTaskBoardWrite               Boolean             @default(true) @map("allow_task_board_write")
  allowDocWrite                     Boolean             @default(true) @map("allow_doc_write")
  highRiskActionsRequireConfirmation Boolean            @default(true) @map("high_risk_actions_require_confirmation")
  archivedAt                        DateTime?           @map("archived_at")
  createdAt                         DateTime            @default(now()) @map("created_at")
  updatedAt                         DateTime            @updatedAt @map("updated_at")
  project                           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultEnvironment                ProjectEnvironment? @relation(fields: [defaultEnvironmentId], references: [id], onDelete: SetNull)

  @@unique([projectId, feishuChatId])
  @@index([feishuChatId])
  @@map("group_policies")
}

model RuntimeEvent {
  id                String              @id @default(uuid()) @db.Uuid
  runtimeSessionKey String              @map("runtime_session_key")
  groupSessionId    String?             @map("group_session_id") @db.Uuid
  projectId         String?             @map("project_id") @db.Uuid
  environmentId     String?             @map("environment_id") @db.Uuid
  sequence          Int
  eventType         String              @map("event_type")
  payload           Json                @default("{}")
  createdAt         DateTime            @default(now()) @map("created_at")
  groupSession      GroupAgentSession?  @relation(fields: [groupSessionId], references: [id], onDelete: SetNull)
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment       ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@unique([runtimeSessionKey, sequence])
  @@index([groupSessionId, createdAt])
  @@index([projectId, createdAt])
  @@map("runtime_events")
}

model ProjectMemberProfile {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  feishuChatId     String   @map("feishu_chat_id")
  openId           String   @map("open_id")
  displayName      String   @map("display_name")
  groupNickname    String?  @map("group_nickname")
  projectRole      String?  @map("project_role")
  responsibility   String?
  permissionLevel  String   @default("member") @map("permission_level")
  isDecisionMaker  Boolean  @default(false) @map("is_decision_maker")
  isTaskAssignable Boolean  @default(true) @map("is_task_assignable")
  metadataJson     Json     @default("{}") @map("metadata_json")
  lastActiveAt     DateTime? @map("last_active_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, feishuChatId, openId])
  @@index([feishuChatId])
  @@map("project_member_profiles")
}

model AgentRoleProfile {
  agentRole         AgentRole @id @map("agent_role")
  agentsMd          String    @default("") @map("agents_md")
  soulMd            String    @default("") @map("soul_md")
  userMdTemplate    String    @default("") @map("user_md_template")
  standingOrdersMd  String    @default("") @map("standing_orders_md")
  skillsJson        Json      @default("[]") @map("skills_json")
  promptPreludeMd   String    @default("") @map("prompt_prelude_md")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  projectOverrides  ProjectAgentProfileOverride[]

  @@map("agent_role_profiles")
}

model ProjectAgentProfileOverride {
  id         String    @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  agentRole   AgentRole @map("agent_role")
  overrideJson Json    @default("{}") @map("override_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profile     AgentRoleProfile @relation(fields: [agentRole], references: [agentRole], onDelete: Cascade)

  @@unique([projectId, agentRole])
  @@index([agentRole])
  @@map("project_agent_profile_overrides")
}
