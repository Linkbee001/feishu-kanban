NODE_ENV=development
PORT=3000
# Default for local PostgreSQL/Redis installed on the host.
DATABASE_URL=postgresql://feishu:feishu@localhost:5432/feishu_kanban?schema=public
REDIS_URL=redis://localhost:6379
# Used only by docker-compose api/worker containers to reach host services.
DOCKER_DATABASE_URL=postgresql://feishu:feishu@host.docker.internal:5432/feishu_kanban?schema=public
DOCKER_REDIS_URL=redis://host.docker.internal:6379

FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_EVENT_MODE=ws
FEISHU_WS_EVENT_TYPES=im.message.receive_v1,im.chat.member.bot.added_v1,card.action.trigger
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Only needed for HTTP webhook mode or encrypted webhook/card callbacks.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# PiMono runs locally inside the worker through the embedded SDK runtime.
# Set provider/model and the corresponding provider API key, for example OPENAI_API_KEY.
# Alibaba Cloud Model Studio / Bailian via DashScope OpenAI-compatible API.
PI_MONO_PROVIDER=bailian
PI_MONO_MODEL=kimi-k2.5
PI_MONO_THINKING_LEVEL=off
PI_MONO_WORKDIR=/workspace
PI_MONO_AGENT_DIR=/workspace/.pi-agent
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

ADMIN_JWT_SECRET=change-me
PUBLIC_BASE_URL=http://localhost:3000
CONFIRMATION_TTL_MINUTES=30
AGENT_RUN_TIMEOUT_SECONDS=1800
