{
  "name": "feishu-kanban",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu project collaboration assistant V1 backend",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:worker": "node dist/src/worker.js",
    "worker:dev": "ts-node -r tsconfig-paths/register src/worker.ts",
    "test": "jest --runInBand",
    "test:pi-runtime": "jest --runInBand test/pi-mono.adapter.spec.ts",
    "test:group-runtime": "jest --runInBand test/group-runtime.service.spec.ts test/feishu-event.service.spec.ts",
    "verify:runtime-fast": "npm run test:pi-runtime && npm run test:group-runtime && npm run build",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.61.1",
    "@mariozechner/pi-coding-agent": "^0.68.1",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@prisma/client": "^6.18.0",
    "bullmq": "^5.61.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "form-data": "^4.0.4",
    "ioredis": "^5.8.2",
    "joi": "^18.0.1",
    "nanoid": "^5.1.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.1",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "prisma": "^6.18.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  }
}
